{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/cdn-proxy/:path*", "destination": "https://ecolabwallchart.azurewebsites.net/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=86400" }
      ]
    }
  ]
}
